# NL-SQL Service — Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env

# ---- API ----
API_PORT=8000
UVICORN_WORKERS=1

# ---- LLM Backend ----
# Set NL_SQL_LLM_PROVIDER to "groq" or "ollama"
NL_SQL_LLM_PROVIDER=ollama
NL_SQL_USE_LLM=true

# Ollama (local or self-hosted) — used when NL_SQL_LLM_PROVIDER=ollama
OLLAMA_URL=http://192.168.12.51:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT=300

# Groq (free cloud) — used when NL_SQL_LLM_PROVIDER=groq
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Other good free models: llama-3.1-8b-instant, mixtral-8x7b-32768

# ---- Logging ----
NL_SQL_LOG_LEVEL=INFO

# ---- Authentication (stub — not enforced yet) ----
NL_SQL_API_KEY_HEADER=X-API-Key

# ---- Config file paths (default: ./current/*.json) ----
# Uncomment to override:
# NL_SQL_METRIC_REGISTRY=/app/current/metric_registry.json
# NL_SQL_PHYSICAL_SCHEMA=/app/current/physical_schema.json
# NL_SQL_FILTER_CONFIG=/app/current/filter_config.json
# NL_SQL_CHUNKS_DIR=

# ---- Fabric Data Warehouse ----
FABRIC_SERVER=2znmjl7mstiu5llfjeqmjr2dhe-q2dw4ssa56cu7m2sosqamokrpq.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=RDMWarehouse
FABRIC_DRIVER=ODBC Driver 17 for SQL Server
FABRIC_ROW_LIMIT=10000
